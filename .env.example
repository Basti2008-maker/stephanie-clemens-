# --- Admin-Bereich ---
# Admin-Code: wird auf der Startseite im Code-Feld eingegeben und öffnet den
# Admin-Bereich (/admin). Wird auch zum Signieren der Session-Cookies verwendet.
# Für die Produktion bitte ein starkes, einzigartiges Passwort setzen.
ADMIN_PASSWORD=bitte-ein-sicheres-passwort-setzen

# --- Gäste-Code für die Startseite ---
# Öffentlicher Code, mit dem Gäste über das Code-Feld zum Anmeldeformular
# gelangen. Darf öffentlich sein (nur eine einfache Zugangshürde).
NEXT_PUBLIC_RSVP_CODE=26.6.27

# --- Datenbank ---
# Lokal: einfache Datei, kein Turso-Account nötig.
DATABASE_URL="file:./dev.db"
# Nur für Turso (Produktion/Vercel) nötig. Lokal leer lassen bzw. Zeile auskommentiert lassen.
# DATABASE_AUTH_TOKEN=
# Alternativ werden auch TURSO_DATABASE_URL / TURSO_AUTH_TOKEN erkannt –
# das sind die Namen, die die Turso-Integration im Vercel-Marketplace
# automatisch setzt.

# --- Platzhalter für die Startseite ---
# Können jederzeit angepasst werden, ohne den Code zu ändern (z. B. sobald die
# Location feststeht). ISO-Format für das Datum, Uhrzeit optional.
NEXT_PUBLIC_WEDDING_DATE=2027-06-26T14:00:00
NEXT_PUBLIC_WEDDING_LOCATION="Location folgt in Kürze"
